{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "cd lightweight-charts-master/lightweight-charts-master/tradingview-ui && npm install --no-audit --no-fund",
  "buildCommand": "cd lightweight-charts-master/lightweight-charts-master/tradingview-ui && npx vite build",
  "outputDirectory": "lightweight-charts-master/lightweight-charts-master/tradingview-ui/dist",
  "framework": null,
  "rewrites": [
    { "source": "/assets/(.*)",                "destination": "/assets/$1" },
    { "source": "/src/(.*)",                   "destination": "/src/$1" },
    { "source": "/figma/(.*)",                 "destination": "/figma/$1" },
    { "source": "/portfolio",                  "destination": "/portfolio/index.html" },
    { "source": "/portfolio/(.*)",             "destination": "/portfolio/$1" },
    { "source": "/options",                    "destination": "/options/index.html" },
    { "source": "/options/(.*)",               "destination": "/options/$1" },
    { "source": "/financial-charts",           "destination": "/financial-charts/index.html" },
    { "source": "/financial-charts/(.*)",      "destination": "/financial-charts/$1" },
    { "source": "/earnings-calendar",          "destination": "/earnings-calendar/index.html" },
    { "source": "/earnings-calendar/(.*)",     "destination": "/earnings-calendar/$1" },
    { "source": "/ipo-calendar",               "destination": "/ipo-calendar/index.html" },
    { "source": "/ipo-calendar/(.*)",          "destination": "/ipo-calendar/$1" },
    { "source": "/heatmap-inflation",          "destination": "/heatmap-inflation/index.html" },
    { "source": "/heatmap-inflation/(.*)",     "destination": "/heatmap-inflation/$1" },
    { "source": "/community",                  "destination": "/index.html" },
    { "source": "/community/(.*)",             "destination": "/index.html" },
    { "source": "/markets",                    "destination": "/index.html" },
    { "source": "/markets/(.*)",               "destination": "/index.html" },
    { "source": "/ideas",                      "destination": "/index.html" },
    { "source": "/ideas/(.*)",                 "destination": "/index.html" },
    { "source": "/scripts",                    "destination": "/index.html" },
    { "source": "/scripts/(.*)",               "destination": "/index.html" },
    { "source": "/((?!.*\\.).*)",              "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
